#!/usr/bin/env python3
"""wall-gui -- GTK4 graphical frontend for the wall wallpaper manager.

Architecture:
    WallGui           Main application window. Left pane: searchable, filterable
                      wallpaper list. Right pane: detail panel with thumbnail,
                      metadata, properties, and actions. Info loading is async
                      (threaded) with GLib.idle_add for thread-safe UI updates.
    PlaylistWindow    Two-pane modal for managing named playlists with drag-and-drop
                      reorder (uses GObject.TYPE_STRING for DnD value passing).
    SettingsWindow    Modal for global settings (FPS, scaling, audio, volume,
                      fullscreen-pause). Writes to ~/.config/wall/config and
                      reloads the daemon on apply.

Data flows:
    - All CLI interaction goes through wall_cmd() which shells out to `wall`.
    - Wallpaper list is loaded once at startup via load_wallpapers(); the user
      can refresh manually.
    - Selecting a wallpaper triggers a debounced async load_info() call that
      populates the detail panel, including properties and video metadata.
    - Property changes are staged in memory and persisted on Apply via
      `wall prop set`.
    - Favorites are a special protected playlist; toggling updates the file
      directly and refreshes the list to show/hide star badges.
"""

import gi
gi.require_version('Gtk', '4.0')
from gi.repository import Gtk, Gdk, GLib, GObject, Pango

import json
import os
import re
import subprocess
import shutil
import threading
from datetime import datetime

MEDIA_EXTS = {".mp4", ".webm", ".gif"}
GUI_LOG_FILE = os.path.expanduser("~/.cache/wall/wall.log")
_LAST_WALL_BIN = None
_WALL_ENV_LOGGED = False


def gui_log(message):
    """Append a timestamped message to the wall-gui log."""
    try:
        os.makedirs(os.path.dirname(GUI_LOG_FILE), exist_ok=True)
        with open(GUI_LOG_FILE, "a") as f:
            ts = datetime.now().strftime("%H:%M:%S")
            f.write(f"{ts} [GUI] {message}\n")
    except OSError:
        pass

########################################
# BBCODE → PANGO MARKUP
########################################

def bbcode_to_pango(text):
    """Convert Wallpaper Engine BBCode to Pango markup for Gtk.Label."""
    # Escape Pango XML special chars first
    text = text.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")

    # Tags that map directly to Pango
    simple = [
        (r'\[b\](.*?)\[/b\]',           r'<b>\1</b>'),
        (r'\[i\](.*?)\[/i\]',           r'<i>\1</i>'),
        (r'\[u\](.*?)\[/u\]',           r'<u>\1</u>'),
        (r'\[s\](.*?)\[/s\]',           r'<s>\1</s>'),
        (r'\[strike\](.*?)\[/strike\]', r'<s>\1</s>'),
        (r'\[h[1-3]\](.*?)\[/h[1-3]\]', r'<b>\1</b>'),
        (r'\[url=([^\]]+)\](.*?)\[/url\]', r'<a href="\1">\2</a>'),
        (r'\[url\](.*?)\[/url\]',        r'<a href="\1">\1</a>'),
        (r'\[img\].*?\[/img\]',          r''),
        (r'\[noparse\](.*?)\[/noparse\]', r'\1'),
        (r'\[list\]|\[/list\]',          r''),
        (r'\[\*\]',                       r'• '),
    ]
    for pattern, repl in simple:
        text = re.sub(pattern, repl, text, flags=re.DOTALL | re.IGNORECASE)

    # Strip any remaining unknown [tags]
    text = re.sub(r'\[/?[a-zA-Z][^\]]*\]', '', text)

    return text.strip()

########################################
# WALL CLI
########################################

def get_wall_bin():
    """Resolve the path to the wall CLI binary.

    Prefer the user-local install so we never accidentally pick up the
    system 'wall' utility (util-linux) which may appear first on the PATH
    when launched from Hyprland's exec environment.
    """
    global _LAST_WALL_BIN
    local = os.path.expanduser("~/.local/bin/wall")
    if os.path.isfile(local) and os.access(local, os.X_OK):
        wall_bin = local
    else:
        wall_bin = shutil.which("wall") or local
    if wall_bin != _LAST_WALL_BIN:
        gui_log(f"wall bin resolved: {wall_bin}")
        _LAST_WALL_BIN = wall_bin
    return wall_bin


def wall_env():
    """Build a stable env for wall subprocesses.

    GUI launchers often provide a trimmed PATH; ensure user-local binaries
    (including engine overrides) are preferred the same way as shell usage.
    """
    global _WALL_ENV_LOGGED
    env = os.environ.copy()
    local_bin = os.path.expanduser("~/.local/bin")
    path = env.get("PATH", "")
    parts = [p for p in path.split(":") if p]
    if local_bin in parts:
        parts = [p for p in parts if p != local_bin]
    parts.insert(0, local_bin)
    env["PATH"] = ":".join(parts)
    if not _WALL_ENV_LOGGED:
        gui_log(f"wall env PATH={env['PATH']}")
        _WALL_ENV_LOGGED = True
    return env


def wall_cmd(*args, timeout=45):
    """Run a wall subcommand, return stdout as a string.

    timeout: seconds to wait before giving up (default 45).  Prevents
    wall-gui from hanging indefinitely when the Steam library drive is
    not yet mounted and wait_for_steam() would otherwise loop forever.
    """
    cmd = [get_wall_bin(), *args]
    gui_log(f"wall_cmd run: {' '.join(cmd)} timeout={timeout}s")
    try:
        proc = subprocess.run(
            cmd,
            capture_output=True, text=True,
            timeout=timeout,
            env=wall_env(),
        )
        stderr = (proc.stderr or "").strip()
        if proc.returncode != 0 or stderr:
            gui_log(f"wall_cmd result: rc={proc.returncode} stderr={stderr or '-'}")
        return proc.stdout
    except subprocess.TimeoutExpired:
        gui_log(f"wall_cmd timeout: {' '.join(cmd)}")
        return ""
    except Exception as exc:
        gui_log(f"wall_cmd exception: {' '.join(cmd)} error={exc}")
        return ""


def load_wallpapers():
    """Fetch wallpaper list via `wall list`.
    Output format: MARKER\\tID\\tTITLE\\tTAGS\\tTYPE
    """
    walls = []
    for line in wall_cmd("list").splitlines():
        parts = line.split("\t")
        if len(parts) >= 3:
            walls.append({
                "active": parts[0].strip() == "*",
                "id":     parts[1],
                "title":  parts[2],
                "tags":   parts[3] if len(parts) > 3 else "",
                "type":   parts[4].capitalize() if len(parts) > 4 else "",
                "desc":   parts[5] if len(parts) > 5 else "",
            })
    return walls


def load_info(wall_id):
    """Fetch full wallpaper details via `wall info <id>`.
    Returns a dict with title, type, description, tags, visibility, thumbnail, id,
    video (optional), properties (optional).
    """
    try:
        return json.loads(wall_cmd("info", wall_id))
    except Exception:
        return {}


def get_monitors():
    """Fetch connected monitors via `wall monitors`."""
    mons = [m.strip() for m in wall_cmd("monitors").splitlines() if m.strip()]
    return mons if mons else ["*"]


def apply_wallpaper(wall_id, monitor):
    """Apply wallpaper via `wall <id> [monitor]`."""
    cmd = [get_wall_bin(), wall_id]
    if monitor != "ALL":
        cmd.append(monitor)
    gui_log(f"apply_wallpaper: {' '.join(cmd)}")
    subprocess.Popen(cmd, env=wall_env())


def load_saved_props(wall_id):
    """Load saved property overrides from ~/.config/wall/props/<id>."""
    props_file = os.path.expanduser(f"~/.config/wall/props/{wall_id}")
    saved = {}
    if os.path.exists(props_file):
        with open(props_file) as f:
            for line in f:
                line = line.strip()
                if "=" in line:
                    k, v = line.split("=", 1)
                    saved[k] = v
    return saved


WALLFLAGS_DIR = os.path.expanduser("~/.config/wall/wallflags")


def load_wall_flags(wall_id):
    """Return set of active flag names for a wallpaper (e.g. 'disable-particles')."""
    path = os.path.join(WALLFLAGS_DIR, wall_id)
    if not os.path.exists(path):
        return set()
    with open(path) as f:
        return {line.strip() for line in f if line.strip()}


def set_wall_flag(wall_id, flag, enabled):
    """Enable or disable a named per-wallpaper flag, persisted to disk."""
    os.makedirs(WALLFLAGS_DIR, exist_ok=True)
    path = os.path.join(WALLFLAGS_DIR, wall_id)
    flags = load_wall_flags(wall_id)
    if enabled:
        flags.add(flag)
    else:
        flags.discard(flag)
    with open(path, "w") as f:
        for fl in sorted(flags):
            f.write(fl + "\n")


def get_active_monitors_for(wall_id):
    """Return list of monitors currently showing wall_id."""
    mon_dir = os.path.expanduser("~/.cache/wall/monitors")
    mons = []
    if os.path.isdir(mon_dir):
        for mon in os.listdir(mon_dir):
            current_f = os.path.join(mon_dir, mon, "current")
            try:
                with open(current_f) as f:
                    if f.read().strip() == wall_id:
                        mons.append(mon)
            except OSError:
                pass
    return mons


def load_config():
    """Read ~/.config/wall/config into a dict."""
    conf = {"fps": "60", "scaling": "fill", "clamp": "border", "audio": "0", "volume": "15", "fullscreen_pause": "0"}
    config_file = os.path.expanduser("~/.config/wall/config")
    if os.path.exists(config_file):
        with open(config_file) as f:
            for line in f:
                line = line.strip()
                if "=" in line and not line.startswith("#"):
                    k, v = line.split("=", 1)
                    conf[k.lower()] = v
    return conf


PLAYLISTS_DIR = os.path.expanduser("~/.config/wall/playlists")
FAVORITES_NAME = "Favorites"


def is_in_favorites(wall_id):
    """Check whether a wallpaper is in the Favorites playlist."""
    return wall_id in set(load_playlist_ids(FAVORITES_NAME))


def toggle_favorite(wall_id):
    """Add to Favorites if not present, remove if present. Auto-creates playlist."""
    favs = load_playlist_ids(FAVORITES_NAME)
    if wall_id in favs:
        playlist_cmd("remove", FAVORITES_NAME, wall_id)
        return False
    else:
        # Auto-create Favorites playlist if it doesn't exist yet
        fav_path = os.path.join(PLAYLISTS_DIR, FAVORITES_NAME)
        if not os.path.exists(fav_path):
            playlist_cmd("create", FAVORITES_NAME)
        playlist_cmd("add", FAVORITES_NAME, wall_id)
        return True


def load_playlists():
    """Return sorted list of playlist names."""
    if not os.path.isdir(PLAYLISTS_DIR):
        return []
    return sorted(
        f for f in os.listdir(PLAYLISTS_DIR)
        if os.path.isfile(os.path.join(PLAYLISTS_DIR, f))
    )


def load_playlist_ids(name):
    """Return ordered list of IDs in a named playlist."""
    path = os.path.join(PLAYLISTS_DIR, name)
    if not os.path.exists(path):
        return []
    with open(path) as f:
        return [line.strip() for line in f if line.strip()]


def playlist_cmd(subcmd, *args):
    """Run a `wall playlist <subcmd> ...` command."""
    wall_cmd("playlist", subcmd, *args)


########################################
# SETTINGS WINDOW
########################################

class SettingsWindow(Gtk.Window):
    """Modal window for editing global settings (FPS, scaling, audio, volume,
    fullscreen-pause, and engine source mode. Writes changes to the config file
    and reloads the daemon.
    """

    # --- Init ---

    def __init__(self, parent):
        super().__init__(title="Settings", transient_for=parent, modal=True)
        self.set_default_size(460, 390)
        self.set_resizable(False)

        conf = load_config()

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        box.set_margin_top(20)
        box.set_margin_bottom(20)
        box.set_margin_start(24)
        box.set_margin_end(24)
        self.set_child(box)

        note = Gtk.Label()
        note.set_markup(
            "<small>These settings apply <b>globally</b> to all wallpapers.\n"
            "Applying will restart the wallpaper engine. Switching to fork\n"
            "downloads the latest fork binary.</small>"
        )
        note.set_halign(Gtk.Align.START)
        note.add_css_class("dim-label")
        box.append(note)

        box.append(Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL))

        grid = Gtk.Grid()
        grid.set_column_spacing(16)
        grid.set_row_spacing(12)
        box.append(grid)

        # FPS
        fps_lbl = Gtk.Label(label="FPS")
        fps_lbl.set_halign(Gtk.Align.START)
        fps_lbl.set_tooltip_text("Render framerate for all wallpapers")
        grid.attach(fps_lbl, 0, 0, 1, 1)

        self._fps_spin = Gtk.SpinButton()
        self._fps_spin.set_adjustment(Gtk.Adjustment(
            value=int(conf.get("fps", 60)),
            lower=1, upper=240, step_increment=1,
            page_increment=10, page_size=0
        ))
        self._fps_spin.set_numeric(True)
        self._fps_spin.set_tooltip_text("Render framerate for all wallpapers")
        grid.attach(self._fps_spin, 1, 0, 1, 1)

        fps_hint = Gtk.Label(label="frames per second")
        fps_hint.set_halign(Gtk.Align.START)
        fps_hint.add_css_class("dim-label")
        grid.attach(fps_hint, 2, 0, 1, 1)

        # Scaling
        scl_lbl = Gtk.Label(label="Scaling")
        scl_lbl.set_halign(Gtk.Align.START)
        scl_lbl.set_tooltip_text("How to fit wallpapers to your screen")
        grid.attach(scl_lbl, 0, 1, 1, 1)

        self._scaling_opts = ["fill", "fit", "stretch", "default"]
        scl_model = Gtk.StringList.new(self._scaling_opts)
        self._scl_drop = Gtk.DropDown(model=scl_model)
        cur_scaling = conf.get("scaling", "fill")
        if cur_scaling in self._scaling_opts:
            self._scl_drop.set_selected(self._scaling_opts.index(cur_scaling))
        self._scl_drop.set_tooltip_text("fill: crop to fit · fit: letterbox · stretch: distort · default: engine decides")
        grid.attach(self._scl_drop, 1, 1, 1, 1)

        scl_hint = Gtk.Label(label="fill · fit · stretch · default")
        scl_hint.set_halign(Gtk.Align.START)
        scl_hint.add_css_class("dim-label")
        grid.attach(scl_hint, 2, 1, 1, 1)

        # Clamp
        clp_lbl = Gtk.Label(label="Clamp")
        clp_lbl.set_halign(Gtk.Align.START)
        clp_lbl.set_tooltip_text("How texture edges are handled when scaling doesn't fill exactly")
        grid.attach(clp_lbl, 0, 2, 1, 1)

        self._clamp_opts = ["border", "clamp", "repeat"]
        clp_model = Gtk.StringList.new(self._clamp_opts)
        self._clp_drop = Gtk.DropDown(model=clp_model)
        cur_clamp = conf.get("clamp", "border")
        if cur_clamp in self._clamp_opts:
            self._clp_drop.set_selected(self._clamp_opts.index(cur_clamp))
        self._clp_drop.set_tooltip_text("border: solid edge · clamp: stretch edge pixel · repeat: tile")
        grid.attach(self._clp_drop, 1, 2, 1, 1)

        clp_hint = Gtk.Label(label="border · clamp · repeat")
        clp_hint.set_halign(Gtk.Align.START)
        clp_hint.add_css_class("dim-label")
        grid.attach(clp_hint, 2, 2, 1, 1)

        # Silent
        sil_lbl = Gtk.Label(label="Silent")
        sil_lbl.set_halign(Gtk.Align.START)
        sil_lbl.set_tooltip_text("Mute all wallpaper audio")
        grid.attach(sil_lbl, 0, 3, 1, 1)

        self._sil_sw = Gtk.Switch()
        self._sil_sw.set_active(conf.get("audio", "0") == "0")
        self._sil_sw.set_halign(Gtk.Align.START)
        self._sil_sw.set_valign(Gtk.Align.CENTER)
        self._sil_sw.set_tooltip_text("Mute all wallpaper audio")
        self._sil_sw.connect("notify::active", self._on_silent_toggled)
        grid.attach(self._sil_sw, 1, 3, 1, 1)

        sil_hint = Gtk.Label(label="mute all wallpaper audio")
        sil_hint.set_halign(Gtk.Align.START)
        sil_hint.add_css_class("dim-label")
        grid.attach(sil_hint, 2, 3, 1, 1)

        # Volume
        vol_lbl = Gtk.Label(label="Volume")
        vol_lbl.set_halign(Gtk.Align.START)
        vol_lbl.set_tooltip_text("Playback volume (0–100)")
        grid.attach(vol_lbl, 0, 4, 1, 1)

        self._vol_scale = Gtk.Scale.new_with_range(
            Gtk.Orientation.HORIZONTAL, 0, 100, 1
        )
        self._vol_scale.set_value(int(conf.get("volume", "15")))
        self._vol_scale.set_draw_value(True)
        self._vol_scale.set_value_pos(Gtk.PositionType.RIGHT)
        self._vol_scale.set_hexpand(True)
        self._vol_scale.set_size_request(160, -1)
        self._vol_scale.set_tooltip_text("Playback volume (0–100)")
        self._vol_scale.set_sensitive(not self._sil_sw.get_active())
        grid.attach(self._vol_scale, 1, 4, 1, 1)

        vol_hint = Gtk.Label(label="0–100")
        vol_hint.set_halign(Gtk.Align.START)
        vol_hint.add_css_class("dim-label")
        grid.attach(vol_hint, 2, 4, 1, 1)

        # Fullscreen pause
        fsp_lbl = Gtk.Label(label="Pause on fullscreen")
        fsp_lbl.set_halign(Gtk.Align.START)
        fsp_lbl.set_tooltip_text("Pause wallpapers when a fullscreen app is open")
        grid.attach(fsp_lbl, 0, 5, 1, 1)

        self._fsp_sw = Gtk.Switch()
        self._fsp_sw.set_active(conf.get("fullscreen_pause", "0") == "1")
        self._fsp_sw.set_halign(Gtk.Align.START)
        self._fsp_sw.set_valign(Gtk.Align.CENTER)
        self._fsp_sw.set_tooltip_text("Pause wallpapers when a fullscreen app is open")
        grid.attach(self._fsp_sw, 1, 5, 1, 1)

        fsp_hint = Gtk.Label(label="on any monitor")
        fsp_hint.set_halign(Gtk.Align.START)
        fsp_hint.add_css_class("dim-label")
        grid.attach(fsp_hint, 2, 5, 1, 1)

        # Engine source
        eng_lbl = Gtk.Label(label="Engine")
        eng_lbl.set_halign(Gtk.Align.START)
        eng_lbl.set_tooltip_text("Choose system engine or managed fork engine")
        grid.attach(eng_lbl, 0, 6, 1, 1)

        self._engine_mode = self._detect_engine_mode(conf)
        self._engine_opts = ["system", "fork"]
        if self._engine_mode == "custom":
            self._engine_opts.append("custom")

        eng_model = Gtk.StringList.new(self._engine_opts)
        self._eng_drop = Gtk.DropDown(model=eng_model)
        self._eng_drop.set_selected(self._engine_opts.index(self._engine_mode))
        self._eng_drop.set_tooltip_text("system: linux-wallpaperengine package · fork: ~/.local/bin/wall-engine")
        grid.attach(self._eng_drop, 1, 6, 1, 1)

        eng_hint = Gtk.Label(
            label=(
                "system · fork"
                if self._engine_mode != "custom"
                else "custom path detected (kept unless changed)"
            )
        )
        eng_hint.set_halign(Gtk.Align.START)
        eng_hint.add_css_class("dim-label")
        grid.attach(eng_hint, 2, 6, 1, 1)

        self._eng_path_lbl = Gtk.Label(label=self._engine_resolution_text(conf))
        self._eng_path_lbl.set_halign(Gtk.Align.START)
        self._eng_path_lbl.set_wrap(True)
        self._eng_path_lbl.add_css_class("dim-label")
        grid.attach(self._eng_path_lbl, 0, 7, 3, 1)

        apply_btn = Gtk.Button(label="Apply")
        apply_btn.add_css_class("suggested-action")
        apply_btn.connect("clicked", self._on_apply)
        box.append(apply_btn)

    # --- Callbacks ---

    def _on_silent_toggled(self, sw, _param):
        """Disable volume slider when silent mode is active."""
        self._vol_scale.set_sensitive(not sw.get_active())

    def _detect_engine_mode(self, conf):
        """Return engine mode: system, fork, or custom."""
        engine_bin = (conf.get("engine_bin", "") or "").strip()
        if not engine_bin:
            return "system"
        if os.path.expanduser(engine_bin) == os.path.expanduser("~/.local/bin/wall-engine"):
            return "fork"
        return "custom"

    def _engine_resolution_text(self, conf):
        """Build a readable engine resolution string for the settings UI."""
        raw = (conf.get("engine_bin", "") or "").strip() or "linux-wallpaperengine"
        expanded = os.path.expanduser(raw)
        if "/" in raw:
            resolved = expanded
            exists = os.path.isfile(resolved) and os.access(resolved, os.X_OK)
        else:
            found = shutil.which(raw)
            resolved = found or raw
            exists = bool(found)
        return f"Configured: {raw}  |  Resolved: {resolved}  ({'ok' if exists else 'missing'})"

    def _on_apply(self, _btn):
        """Persist all settings to the config file and reload the daemon."""
        updates = {
            "FPS":              str(int(self._fps_spin.get_value())),
            "SCALING":          self._scaling_opts[self._scl_drop.get_selected()],
            "CLAMP":            self._clamp_opts[self._clp_drop.get_selected()],
            "AUDIO":            "0" if self._sil_sw.get_active() else "1",
            "VOLUME":           str(int(self._vol_scale.get_value())),
            "FULLSCREEN_PAUSE": "1" if self._fsp_sw.get_active() else "0",
        }
        config_file = os.path.expanduser("~/.config/wall/config")
        os.makedirs(os.path.dirname(config_file), exist_ok=True)
        conf = {}
        if os.path.exists(config_file):
            with open(config_file) as f:
                for line in f:
                    line = line.strip()
                    if "=" in line and not line.startswith("#"):
                        k, v = line.split("=", 1)
                        conf[k.upper()] = v
        conf.update(updates)
        with open(config_file, "w") as f:
            for k, v in conf.items():
                f.write(f"{k}={v}\n")

        engine_mode = self._engine_opts[self._eng_drop.get_selected()]
        if engine_mode in {"system", "fork"} and engine_mode != self._engine_mode:
            gui_log(f"settings apply: engine switch requested mode={engine_mode}")
            wall_cmd("use-engine", engine_mode, timeout=180)

        gui_log(f"settings apply: updates={updates}")
        wall_cmd("reload")
        self.close()


########################################
# PLAYLIST WINDOW
########################################

class PlaylistWindow(Gtk.Window):
    """Two-pane playlist manager. Left: playlist list. Right: playlist contents
    with drag-and-drop reordering. Toolbar provides monitor/interval selectors
    and Play/Shuffle buttons.
    """

    # --- Init ---

    def __init__(self, parent, all_walls):
        super().__init__(title="Playlists", transient_for=parent)
        self.set_default_size(800, 520)
        self.all_walls = {w["id"]: w["title"] for w in all_walls}
        self._selected_playlist = None

        self._build_ui()
        self._refresh_playlists()

    # --- UI building ---

    def _build_ui(self):
        """Construct the toolbar, paned layout, playlist list, and contents list."""
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.set_child(root)

        # Toolbar
        toolbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        toolbar.set_margin_top(8)
        toolbar.set_margin_bottom(8)
        toolbar.set_margin_start(8)
        toolbar.set_margin_end(8)

        new_btn = Gtk.Button(label="New Playlist")
        new_btn.connect("clicked", self._on_new_playlist)
        toolbar.append(new_btn)

        self._delete_btn = Gtk.Button(label="Delete")
        self._delete_btn.set_sensitive(False)
        self._delete_btn.connect("clicked", self._on_delete_playlist)
        toolbar.append(self._delete_btn)

        spacer = Gtk.Box()
        spacer.set_hexpand(True)
        toolbar.append(spacer)

        toolbar.append(Gtk.Separator(orientation=Gtk.Orientation.VERTICAL))

        play_on_lbl = Gtk.Label(label="Play on:")
        play_on_lbl.add_css_class("dim-label")
        toolbar.append(play_on_lbl)

        monitors = get_monitors()
        mon_choices = monitors + (["ALL monitors"] if len(monitors) > 1 else [])
        mon_model = Gtk.StringList.new(mon_choices)
        self._mon_drop = Gtk.DropDown(model=mon_model)
        if len(monitors) > 1:
            self._mon_drop.set_selected(len(monitors))
        self._mon_drop.set_tooltip_text("Which monitor to play the playlist on")
        toolbar.append(self._mon_drop)

        every_lbl = Gtk.Label(label="every")
        every_lbl.add_css_class("dim-label")
        toolbar.append(every_lbl)

        self._interval_spin = Gtk.SpinButton()
        self._interval_spin.set_adjustment(Gtk.Adjustment(
            value=300, lower=10, upper=86400,
            step_increment=30, page_increment=300, page_size=0
        ))
        self._interval_spin.set_numeric(True)
        self._interval_spin.set_tooltip_text("Seconds between wallpaper changes")
        self._interval_spin.set_size_request(80, -1)
        toolbar.append(self._interval_spin)

        s_lbl = Gtk.Label(label="s")
        s_lbl.add_css_class("dim-label")
        toolbar.append(s_lbl)

        toolbar.append(Gtk.Separator(orientation=Gtk.Orientation.VERTICAL))

        self._play_btn = Gtk.Button(label="▶ Play")
        self._play_btn.add_css_class("suggested-action")
        self._play_btn.set_sensitive(False)
        self._play_btn.connect("clicked", self._on_play)
        toolbar.append(self._play_btn)

        self._shuffle_btn = Gtk.Button(label="⇄ Shuffle")
        self._shuffle_btn.set_sensitive(False)
        self._shuffle_btn.connect("clicked", self._on_shuffle)
        toolbar.append(self._shuffle_btn)

        root.append(toolbar)
        root.append(Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL))

        paned = Gtk.Paned(orientation=Gtk.Orientation.HORIZONTAL)
        paned.set_vexpand(True)
        paned.set_position(220)
        root.append(paned)

        # Left: playlist list
        left_scroll = Gtk.ScrolledWindow()
        left_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self._pl_listbox = Gtk.ListBox()
        self._pl_listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self._pl_listbox.connect("row-selected", self._on_pl_selected)
        left_scroll.set_child(self._pl_listbox)
        paned.set_start_child(left_scroll)
        paned.set_shrink_start_child(False)

        # Right: contents
        right_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)

        right_toolbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        right_toolbar.set_margin_top(8)
        right_toolbar.set_margin_bottom(8)
        right_toolbar.set_margin_start(8)
        right_toolbar.set_margin_end(8)

        self._remove_btn = Gtk.Button(label="Remove Selected")
        self._remove_btn.set_sensitive(False)
        self._remove_btn.connect("clicked", self._on_remove_entry)
        right_toolbar.append(self._remove_btn)

        right_box.append(right_toolbar)
        right_box.append(Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL))

        right_scroll = Gtk.ScrolledWindow()
        right_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        right_scroll.set_vexpand(True)
        self._content_listbox = Gtk.ListBox()
        self._content_listbox.set_selection_mode(Gtk.SelectionMode.MULTIPLE)
        right_scroll.set_child(self._content_listbox)
        right_box.append(right_scroll)

        paned.set_end_child(right_box)
        paned.set_shrink_end_child(False)

    # --- List population ---

    def _refresh_playlists(self):
        """Reload the playlist list and clear the contents pane."""
        child = self._pl_listbox.get_first_child()
        while child:
            nxt = child.get_next_sibling()
            self._pl_listbox.remove(child)
            child = nxt

        for name in load_playlists():
            row = Gtk.ListBoxRow()
            row.pl_name = name
            ids = load_playlist_ids(name)
            lbl = Gtk.Label(label=f"{name}  ({len(ids)})")
            lbl.set_halign(Gtk.Align.START)
            lbl.set_margin_top(6)
            lbl.set_margin_bottom(6)
            lbl.set_margin_start(12)
            lbl.set_margin_end(12)
            row.set_child(lbl)
            self._pl_listbox.append(row)

        self._selected_playlist = None
        self._delete_btn.set_sensitive(False)
        self._play_btn.set_sensitive(False)
        self._shuffle_btn.set_sensitive(False)
        self._refresh_contents()

    def _refresh_contents(self):
        """Reload the right-pane contents for the currently selected playlist."""
        child = self._content_listbox.get_first_child()
        while child:
            nxt = child.get_next_sibling()
            self._content_listbox.remove(child)
            child = nxt
        self._remove_btn.set_sensitive(False)

        if not self._selected_playlist:
            return

        self._content_listbox.connect(
            "selected-rows-changed",
            lambda _: self._remove_btn.set_sensitive(
                bool(self._content_listbox.get_selected_rows())
            )
        )

        for wall_id in load_playlist_ids(self._selected_playlist):
            self._content_listbox.append(self._make_content_row(wall_id))

    # --- Selection callbacks ---

    def _on_pl_selected(self, _lb, row):
        """Handle playlist selection: enable/disable buttons, refresh contents."""
        if row is None:
            self._selected_playlist = None
            self._delete_btn.set_sensitive(False)
            self._play_btn.set_sensitive(False)
            self._shuffle_btn.set_sensitive(False)
            self._refresh_contents()
            return
        self._selected_playlist = row.pl_name
        ids = load_playlist_ids(row.pl_name)
        has_entries = len(ids) > 0
        self._delete_btn.set_sensitive(row.pl_name != FAVORITES_NAME)
        self._play_btn.set_sensitive(has_entries)
        self._shuffle_btn.set_sensitive(has_entries)
        self._refresh_contents()

    # --- Actions ---

    def _on_new_playlist(self, _btn):
        """Show a dialog to create a new playlist."""
        win = Gtk.Window(title="New Playlist", transient_for=self, modal=True)
        win.set_default_size(320, 120)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_top(16)
        box.set_margin_bottom(16)
        box.set_margin_start(16)
        box.set_margin_end(16)
        entry = Gtk.Entry()
        entry.set_placeholder_text("Playlist name")
        box.append(entry)
        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        ok_btn = Gtk.Button(label="Create")
        ok_btn.add_css_class("suggested-action")
        cancel_btn = Gtk.Button(label="Cancel")
        cancel_btn.connect("clicked", lambda _: win.close())
        btn_row.append(cancel_btn)
        btn_row.append(ok_btn)
        box.append(btn_row)
        win.set_child(box)

        def _do_create(_b):
            name = entry.get_text().strip()
            if name:
                playlist_cmd("create", name)
                win.close()
                self._refresh_playlists()

        ok_btn.connect("clicked", _do_create)
        entry.connect("activate", _do_create)
        win.present()

    def _on_delete_playlist(self, _btn):
        """Confirm and delete the selected playlist. Favorites cannot be deleted."""
        if not self._selected_playlist or self._selected_playlist == FAVORITES_NAME:
            return
        confirm = Gtk.Window(title="Delete Playlist", transient_for=self, modal=True)
        confirm.set_default_size(300, 120)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_top(16)
        box.set_margin_bottom(16)
        box.set_margin_start(16)
        box.set_margin_end(16)
        lbl = Gtk.Label(label=f"Delete playlist '{self._selected_playlist}'?")
        lbl.set_wrap(True)
        box.append(lbl)
        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        yes_btn = Gtk.Button(label="Delete")
        yes_btn.add_css_class("destructive-action")
        no_btn = Gtk.Button(label="Cancel")
        no_btn.connect("clicked", lambda _: confirm.close())
        btn_row.append(no_btn)
        btn_row.append(yes_btn)
        box.append(btn_row)
        confirm.set_child(box)

        def _do_delete(_b):
            playlist_cmd("delete", self._selected_playlist)
            confirm.close()
            self._refresh_playlists()

        yes_btn.connect("clicked", _do_delete)
        confirm.present()

    def _on_remove_entry(self, _btn):
        """Remove selected entries from the current playlist."""
        if not self._selected_playlist:
            return
        selected_rows = self._content_listbox.get_selected_rows()
        ids_to_remove = [r.wall_id for r in selected_rows]
        for wid in ids_to_remove:
            playlist_cmd("remove", self._selected_playlist, wid)
        pl_name = self._selected_playlist
        self._refresh_playlists()
        # Re-select the same playlist
        child = self._pl_listbox.get_first_child()
        while child:
            if hasattr(child, "pl_name") and child.pl_name == pl_name:
                self._pl_listbox.select_row(child)
                break
            child = child.get_next_sibling()

    def _on_play(self, _btn):
        """Start ordered playlist playback on the selected monitor."""
        if not self._selected_playlist:
            return
        item = self._mon_drop.get_selected_item()
        monitor = item.get_string() if item else "ALL monitors"
        interval = str(int(self._interval_spin.get_value()))
        args = ["playlist", "play", self._selected_playlist, interval]
        if monitor != "ALL monitors":
            args.append(monitor)
        gui_log(f"playlist play: name={self._selected_playlist} interval={interval} monitor={monitor}")
        wall_cmd(*args)

    def _on_shuffle(self, _btn):
        """Start shuffled playlist playback on the selected monitor."""
        if not self._selected_playlist:
            return
        item = self._mon_drop.get_selected_item()
        monitor = item.get_string() if item else "ALL monitors"
        interval = str(int(self._interval_spin.get_value()))
        args = ["playlist", "shuffle", self._selected_playlist, interval]
        if monitor != "ALL monitors":
            args.append(monitor)
        gui_log(f"playlist shuffle: name={self._selected_playlist} interval={interval} monitor={monitor}")
        wall_cmd(*args)

    # --- Drag and drop ---

    def _make_content_row(self, wall_id):
        """Build a ListBoxRow for a playlist entry, with a drag handle."""
        row = Gtk.ListBoxRow()
        row.wall_id = wall_id
        title = self.all_walls.get(wall_id, "[unknown]")

        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        box.set_margin_top(4)
        box.set_margin_bottom(4)
        box.set_margin_start(12)
        box.set_margin_end(12)

        handle = Gtk.Label(label="⠿")
        handle.add_css_class("dim-label")
        handle.set_tooltip_text("Drag to reorder")
        box.append(handle)

        lbl = Gtk.Label(label=title)
        lbl.set_halign(Gtk.Align.START)
        lbl.set_hexpand(True)
        lbl.set_ellipsize(Pango.EllipsizeMode.END)
        box.append(lbl)

        id_lbl = Gtk.Label(label=wall_id)
        id_lbl.add_css_class("dim-label")
        box.append(id_lbl)

        row.set_child(box)

        # Drag source — provide this row's wall_id as a string
        drag_src = Gtk.DragSource.new()
        drag_src.set_actions(Gdk.DragAction.MOVE)
        drag_src.connect("prepare", self._on_drag_prepare, row)
        row.add_controller(drag_src)

        # Drop target — accept a wall_id string and reorder
        drop_tgt = Gtk.DropTarget.new(GObject.TYPE_STRING, Gdk.DragAction.MOVE)
        drop_tgt.connect("drop", self._on_drop, row)
        row.add_controller(drop_tgt)

        return row

    def _on_drag_prepare(self, _src, _x, _y, row):
        """Provide the dragged row's wall_id as a string content value."""
        v = GObject.Value(GObject.TYPE_STRING)
        v.set_string(row.wall_id)
        return Gdk.ContentProvider.new_for_value(v)

    def _on_drop(self, _tgt, value, _x, y, target_row):
        """Reorder playlist entries on drop. Insert before or after target row
        depending on whether the drop point is in the upper or lower half.
        """
        dragged_id = value
        if dragged_id == target_row.wall_id or not self._selected_playlist:
            return False
        ids = load_playlist_ids(self._selected_playlist)
        if dragged_id not in ids:
            return False

        # Find target index in current listbox
        idx = 0
        child = self._content_listbox.get_first_child()
        target_idx = 0
        while child:
            if child is target_row:
                target_idx = idx
                break
            idx += 1
            child = child.get_next_sibling()

        # Insert after if drop is in the lower half of the target row
        if y > target_row.get_height() / 2:
            target_idx += 1

        ids.remove(dragged_id)
        ids.insert(target_idx, dragged_id)
        self._save_playlist_order(ids)
        self._refresh_contents()
        return True

    def _save_playlist_order(self, ids):
        """Write the reordered ID list back to the playlist file."""
        pl_path = os.path.join(PLAYLISTS_DIR, self._selected_playlist)
        with open(pl_path, "w") as f:
            f.write("\n".join(ids) + ("\n" if ids else ""))


