    # --- Async data loading ---

    def _show_loading_row(self):
        """Show a spinner row in the listbox while wallpapers are loading."""
        row = Gtk.ListBoxRow(selectable=False)
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.set_margin_top(24)
        box.set_margin_bottom(24)
        box.set_margin_start(20)
        box.set_margin_end(20)
        spinner = Gtk.Spinner()
        spinner.start()
        box.append(spinner)
        lbl = Gtk.Label(label="Loading wallpapers\u2026")
        lbl.add_css_class("dim-label")
        box.append(lbl)
        row.set_child(box)
        self.listbox.append(row)

    def _load_data_async(self):
        """Fetch wallpapers, monitors, and favorites in a background thread.

        If 'wall list' times out (Steam library drive not yet mounted),
        walls will be empty and the UI will show an appropriate message
        with a Refresh button rather than spinning forever.
        """
        walls    = load_wallpapers()
        monitors = get_monitors()
        favs     = set(load_playlist_ids(FAVORITES_NAME))
        gui_log(f"initial load: wallpapers={len(walls)} monitors={','.join(monitors)} favorites={len(favs)}")
        GLib.idle_add(self._on_data_loaded, walls, monitors, favs)

    def _on_data_loaded(self, walls, monitors, favs):
        """Called on the main thread once background loading completes."""
        self.wallpapers = walls
        self.monitors   = monitors
        self._favorites = favs

        # Rebuild monitor dropdown with real data
        mon_list = Gtk.StringList.new(self.monitors + (["ALL"] if len(self.monitors) > 1 else []))
        self.mon_drop.set_model(mon_list)
        if len(self.monitors) > 1:
            self.mon_drop.set_selected(len(self.monitors))

        # Clear loading row then populate for real
        child = self.listbox.get_first_child()
        while child:
            nxt = child.get_next_sibling()
            self.listbox.remove(child)
            child = nxt

        self._populate_list()
        self._update_count()
        self._refresh_status()
        return False  # do not repeat via GLib

    # --- List population ---

    def _populate_list(self):
        """Fill the left-pane ListBox with wallpaper rows, or show an empty state."""
        if not self.wallpapers:
            empty = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
            empty.set_valign(Gtk.Align.CENTER)
            empty.set_vexpand(True)
            empty.set_margin_top(40)
            empty.set_margin_bottom(40)
            empty.set_margin_start(24)
            empty.set_margin_end(24)

            icon = Gtk.Label(label="¯\\_(ツ)_/¯")
            icon.add_css_class("title-1")
            empty.append(icon)

            msg = Gtk.Label()
            msg.set_markup(
                "<b>No wallpapers found.</b>\n\n"
                "The SteamLibrary drive may not be\n"
                "mounted yet. Click <b>↻</b> to retry\n"
                "once the drive is available.\n\n"
                "<tt>wall cache rebuild</tt>  to force a rescan."
            )
            msg.set_justify(Gtk.Justification.CENTER)
            msg.add_css_class("dim-label")
            empty.append(msg)

            self.listbox.append(Gtk.ListBoxRow(child=empty, selectable=False))
            return

        for wall in self.wallpapers:
            row = Gtk.ListBoxRow()
            row.wall = wall

            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            box.set_margin_top(6)
            box.set_margin_bottom(6)
            box.set_margin_start(12)
            box.set_margin_end(12)

            if wall["active"]:
                dot = Gtk.Label(label="▶")
                dot.add_css_class("accent")
                box.append(dot)

            if wall["id"] in self._favorites:
                star = Gtk.Label(label="★")
                star.add_css_class("accent")
                box.append(star)

            text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            text_box.set_hexpand(True)

            title = Gtk.Label(label=wall["title"])
            title.set_halign(Gtk.Align.START)
            title.set_ellipsize(Pango.EllipsizeMode.END)
            text_box.append(title)

            sub = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
            if wall["type"]:
                type_lbl = Gtk.Label(label=wall["type"])
                type_lbl.add_css_class("dim-label")
                type_lbl.set_halign(Gtk.Align.START)
                sub.append(type_lbl)

            if wall["tags"]:
                tags_lbl = Gtk.Label(label=wall["tags"])
                tags_lbl.set_halign(Gtk.Align.START)
                tags_lbl.set_ellipsize(Pango.EllipsizeMode.END)
                tags_lbl.add_css_class("dim-label")
                sub.append(tags_lbl)

            if wall["type"] or wall["tags"]:
                text_box.append(sub)

            box.append(text_box)
            row.set_child(box)
            self.listbox.append(row)

    # --- Filtering ---

    def _matches_filter(self, w):
        """Return True if a wallpaper dict matches the active type and text filters."""
        if self._type_filter and w["type"].lower() != self._type_filter:
            return False
        query = self.search.get_text().lower()
        if not query:
            return True
        return query in w["title"].lower() or query in w["tags"].lower() or query in w["desc"].lower()

    def _filter(self, row):
        """ListBox filter callback."""
        if not hasattr(row, "wall"):
            return True
        return self._matches_filter(row.wall)

    def _on_search_changed(self, _entry):
        """Re-filter and update count when search text changes."""
        self.listbox.invalidate_filter()
        self._update_count()

    def _update_count(self):
        """Update the 'N / total' counter label in the filter bar."""
        count = sum(1 for w in self.wallpapers if self._matches_filter(w))
        total = len(self.wallpapers)
        self._count_label.set_text(
            f"{total} wallpapers" if count == total else f"{count} / {total}"
        )

    def _on_type_filter(self, btn, typ):
        """Handle type filter chip click: ensure mutual exclusivity."""
        for t, b in self._type_btns.items():
            if t != typ:
                b.set_active(False)
        if not btn.get_active():
            btn.set_active(True)
            return
        self._type_filter = typ
        self.listbox.invalidate_filter()
        self._update_count()

    # --- Selection and info loading ---

    def _on_selected(self, _listbox, row):
        """Single click -- enable action buttons immediately, then kick off a
        debounced async info load to populate the detail panel.
        """
        if row is None or not hasattr(row, "wall"):
            return
        wall = row.wall
        self.selected_id = wall["id"]

        self.apply_btn.set_sensitive(True)
        self.share_btn.set_sensitive(True)
        self.open_btn.set_sensitive(True)
        self.playlist_btn.set_sensitive(True)
        self.copy_id_btn.set_sensitive(True)
        self.report_btn.set_sensitive(True)
        self._fav_btn.set_sensitive(True)
        self._fav_btn.set_label("★" if wall["id"] in self._favorites else "☆")
        self._fav_btn.set_tooltip_text(
            "Remove from Favorites" if wall["id"] in self._favorites else "Add to Favorites"
        )

        # Sync per-wallpaper flag checkboxes (block signals to avoid re-entrancy)
        active_flags = load_wall_flags(wall["id"])
        for flag, cb in self._flag_checks.items():
            cb.handler_block_by_func(self._on_flag_toggled)
            cb.set_active(flag in active_flags)
            cb.handler_unblock_by_func(self._on_flag_toggled)
        self._flags_box.set_visible(True)

        # Reset panel to cached data while full info loads
        self.title_label.set_text(wall["title"])
        self.type_label.set_text(wall["type"])
        self.active_label.set_text("· active" if wall["active"] else "")
        self.visibility_label.set_text("")
        self.resolution_label.set_text("")
        self.desc_label.set_text("")
        self.desc_label.set_visible(False)
        self._show_more_btn.set_visible(False)
        self.tags_label.set_text("")
        self.id_label.set_text(f"ID: {wall['id']}")
        self._warn_box.set_visible(False)
        self._error_box.set_visible(False)

        # Cancel any pending debounce
        if self._debounce_id is not None:
            GLib.source_remove(self._debounce_id)
        self._debounce_id = GLib.timeout_add(150, self._start_load_info, wall)

    def _start_load_info(self, wall):
        """Spawn a background thread to load full wallpaper info via CLI."""
        self._debounce_id = None
        load_id = wall["id"]
        self._spinner.start()
        self._spinner.set_visible(True)

        def _load():
            info = load_info(load_id)
            GLib.idle_add(self._on_info_loaded, load_id, wall, info)

        threading.Thread(target=_load, daemon=True).start()
        return False

    def _on_info_loaded(self, load_id, wall, info):
        """Populate the detail panel with loaded info. Called via GLib.idle_add
        to ensure thread-safe GTK updates. Discards stale results if the user
        has already selected a different wallpaper.
        """
        if load_id != self.selected_id:
            return
        self._spinner.stop()
        self._spinner.set_visible(False)

        if info.get("unsupported", False):
            wtype = info.get("type", "").capitalize()
            self._error_label.set_markup(
                f"<big><b>{wtype} wallpapers are not supported by linux-wallpaperengine "
                f"and may crash or display incorrectly.</b></big>"
            )
            self._error_box.set_visible(True)
        else:
            self._error_box.set_visible(False)

        warn_lines = []
        for w in info.get("warnings", []):
            warn_lines.append(w)
        for issue in info.get("runtime_issues", []):
            warn_lines.append(f"⚠ Last run skipped: {issue}")
        for note in info.get("compat_notes", []):
            warn_lines.append(f"ℹ {note}")
        report_count = info.get("report_count", 0)
        if report_count:
            s = "s" if report_count > 1 else ""
            warn_lines.append(f"📋 {report_count} user report{s} filed for this wallpaper")
        if warn_lines:
            self._warn_label.set_markup(
                "<big><b>" + "\n".join(GLib.markup_escape_text(l) for l in warn_lines) + "</b></big>"
            )
            self._warn_box.set_visible(True)
        else:
            self._warn_box.set_visible(False)

        self.title_label.set_text(info.get("title", wall["title"]))
        self.type_label.set_text(info.get("type", wall["type"]).capitalize())

        visibility = info.get("visibility", "")
        self.visibility_label.set_text(f"· {visibility}" if visibility else "")
        self.active_label.set_text("· active" if wall["active"] else "")

        video = info.get("video", {})
        if video and video.get("width"):
            w, h  = video["width"], video["height"]
            fps   = int(video.get("fps", 0))
            dur   = int(video.get("duration", 0))
            codec = video.get("codec", "")
            parts = [f"{w}×{h}"]
            if fps:   parts.append(f"{fps}fps")
            if dur:   parts.append(f"{dur // 60}:{dur % 60:02d}")
            if codec: parts.append(codec)
            self.resolution_label.set_text(" · ".join(parts))
        else:
            self.resolution_label.set_text("")

        desc = info.get("description", "").strip()
        if desc:
            try:
                self.desc_label.set_markup(bbcode_to_pango(desc))
            except Exception:
                self.desc_label.set_text(desc)
        else:
            self.desc_label.set_text("")
        self.desc_label.set_visible(bool(desc))

        self._desc_expanded = False
        self.desc_label.set_lines(4)
        self.desc_label.set_ellipsize(Pango.EllipsizeMode.END)
        self._show_more_btn.set_visible(bool(desc) and len(desc) > 200)
        self._show_more_btn.set_label("Show more")

        tags = ", ".join(info.get("tags", [])) or wall["tags"]
        self.tags_label.set_text(f"Tags: {tags}" if tags else "")
        self.id_label.set_text(f"ID: {wall['id']}")

        self._update_preview(info.get("thumbnail", ""))
        self._build_properties_panel(info.get("properties", []), wall["id"])

    def _update_preview(self, thumb):
        """Set the thumbnail preview; uses Gtk.MediaFile for video/gif previews."""
        if self._current_media is not None:
            self._current_media.pause()
            self._current_media = None

        if not thumb:
            self.thumbnail.set_file(None)
            return

        ext = os.path.splitext(thumb)[1].lower()
        if ext in MEDIA_EXTS:
            try:
                media = Gtk.MediaFile.new_for_filename(thumb)
                media.set_loop(True)
                media.play()
                self.thumbnail.set_paintable(media)
                self._current_media = media
            except Exception:
                self.thumbnail.set_filename(thumb)
        else:
            self.thumbnail.set_filename(thumb)

    # --- Properties panel ---

    def _build_properties_panel(self, properties, wall_id):
        """Rebuild the properties section for the selected wallpaper."""
        # clear existing widgets
        child = self._props_box.get_first_child()
        while child:
            nxt = child.get_next_sibling()
            self._props_box.remove(child)
            child = nxt

        self._staged_props = {}
        self._props_box.set_visible(False)

        if not properties:
            return

        saved = load_saved_props(wall_id)

        self._props_box.set_visible(True)

        sep = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        self._props_box.append(sep)

        header = Gtk.Label(label="Properties")
        header.set_halign(Gtk.Align.START)
        header.add_css_class("heading")
        self._props_box.append(header)

        grid = Gtk.Grid()
        grid.set_column_spacing(12)
        grid.set_row_spacing(8)
        self._props_box.append(grid)

        for i, prop in enumerate(properties):
            key   = prop.get("key", "")
            ptype = prop.get("type", "")
            label_text = prop.get("label", key)
            current_val = saved.get(key, prop.get("value", ""))

            lbl = Gtk.Label(label=label_text)
            lbl.set_halign(Gtk.Align.START)
            lbl.set_hexpand(True)
            grid.attach(lbl, 0, i, 1, 1)

            widget = self._make_prop_widget(key, ptype, current_val, prop)
            if widget:
                grid.attach(widget, 1, i, 1, 1)

    def _make_prop_widget(self, key, ptype, value, prop):
        """Create the appropriate GTK widget for a wallpaper property type."""
        if ptype == "bool":
            sw = Gtk.Switch()
            sw.set_active(str(value).lower() in ("true", "1"))
            sw.set_halign(Gtk.Align.START)
            sw.set_valign(Gtk.Align.CENTER)
            sw.connect("state-set", lambda w, s: self._stage(key, "true" if s else "false"))
            return sw

        if ptype == "slider":
            try:
                lo   = float(prop.get("min") or 0)
                hi   = float(prop.get("max") or 1)
                step = float(prop.get("step") or 0.01)
                cur  = float(value) if value else lo
            except (ValueError, TypeError):
                lo, hi, step, cur = 0.0, 1.0, 0.01, 0.0

            adj   = Gtk.Adjustment(value=cur, lower=lo, upper=hi, step_increment=step)
            scale = Gtk.Scale(orientation=Gtk.Orientation.HORIZONTAL, adjustment=adj)
            scale.set_hexpand(True)
            scale.set_size_request(160, -1)
            scale.set_draw_value(True)
            scale.set_digits(2)
            scale.connect("value-changed", lambda w: self._stage(key, f"{w.get_value():.4g}"))
            return scale

        if ptype == "color":
            try:
                parts = [float(x) for x in str(value).split()]
                r = parts[0] if len(parts) > 0 else 1.0
                g = parts[1] if len(parts) > 1 else 1.0
                b = parts[2] if len(parts) > 2 else 1.0
            except (ValueError, IndexError):
                r, g, b = 1.0, 1.0, 1.0

            rgba = Gdk.RGBA()
            rgba.red, rgba.green, rgba.blue, rgba.alpha = r, g, b, 1.0
            btn = Gtk.ColorButton()
            btn.set_rgba(rgba)
            btn.connect("color-set", lambda w: self._on_color_set(w, key))
            return btn

        if ptype == "combo":
            options = prop.get("options") or []
            if options:
                labels = [o.get("label", str(o.get("value", ""))) for o in options]
                values = [str(o.get("value", "")) for o in options]
                model  = Gtk.StringList.new(labels)
                dd     = Gtk.DropDown(model=model)
                try:
                    dd.set_selected(values.index(str(value)))
                except ValueError:
                    pass
                dd.connect("notify::selected",
                           lambda w, _: self._on_combo_changed(w, key, values))
                return dd

        if ptype in ("text", "textinput"):
            entry = Gtk.Entry()
            entry.set_text(str(value))
            entry.set_hexpand(True)
            entry.connect("changed", lambda w: self._stage(key, w.get_text()))
            return entry

        return None

    def _stage(self, key, value):
        """Stage a property change in memory (persisted on Apply)."""
        self._staged_props[key] = value

    def _on_color_set(self, btn, key):
        """Stage a color property as 'R G B' floats."""
        rgba = btn.get_rgba()
        self._staged_props[key] = f"{rgba.red:.4f} {rgba.green:.4f} {rgba.blue:.4f}"

    def _on_combo_changed(self, dropdown, key, values):
        """Stage a combo property change using the values list."""
        idx = dropdown.get_selected()
        if 0 <= idx < len(values):
            self._staged_props[key] = values[idx]

    def _on_toggle_desc(self, _btn):
        """Toggle between truncated and full description display."""
        self._desc_expanded = not self._desc_expanded
        if self._desc_expanded:
            self.desc_label.set_lines(0)
            self.desc_label.set_ellipsize(Pango.EllipsizeMode.NONE)
            self._show_more_btn.set_label("Show less")
        else:
            self.desc_label.set_lines(4)
            self.desc_label.set_ellipsize(Pango.EllipsizeMode.END)
            self._show_more_btn.set_label("Show more")

    # --- Per-wallpaper flags ---

    def _on_flag_toggled(self, btn, flag):
        """Persist flag change and re-launch wallpaper on active monitors."""
        if not self.selected_id:
            return
        gui_log(f"flag toggled: id={self.selected_id} flag={flag} enabled={btn.get_active()}")
        set_wall_flag(self.selected_id, flag, btn.get_active())
        for mon in get_active_monitors_for(self.selected_id):
            wall_cmd(self.selected_id, mon)

    # --- Favorites ---

    def _on_toggle_favorite(self, _btn):
        """Add or remove the selected wallpaper from Favorites."""
        if not self.selected_id:
            return
        now_fav = toggle_favorite(self.selected_id)
        self._favorites = set(load_playlist_ids(FAVORITES_NAME))
        self._fav_btn.set_label("★" if now_fav else "☆")
        self._fav_btn.set_tooltip_text(
            "Remove from Favorites" if now_fav else "Add to Favorites"
        )
        # Refresh list to update badges
        self._reload_list()

    def _reload_list(self):
        """Repopulate the list without losing the current selection."""
        self.wallpapers = load_wallpapers()
        self._favorites = set(load_playlist_ids(FAVORITES_NAME))
        gui_log(f"reload list: wallpapers={len(self.wallpapers)} favorites={len(self._favorites)}")
        child = self.listbox.get_first_child()
        while child:
            nxt = child.get_next_sibling()
            self.listbox.remove(child)
            child = nxt
        self._populate_list()
        self._update_count()

    def _on_refresh(self, _btn):
        """Refresh button callback: reload wallpapers and update status."""
        self._reload_list()
        self._refresh_status()

    # --- Status bar ---

    def _refresh_status(self):
        """Read per-monitor state files and update the bottom status strip.
        Called on a 3-second GLib timer; returns True to keep the timer alive.
        """
        mon_dir = os.path.expanduser("~/.cache/wall/monitors")
        parts = []
        if os.path.isdir(mon_dir):
            id_to_title = {w["id"]: w["title"] for w in self.wallpapers}
            for mon in sorted(os.listdir(mon_dir)):
                mon_path = os.path.join(mon_dir, mon)
                if not os.path.isdir(mon_path):
                    continue
                current_f = os.path.join(mon_path, "current")
                mode_f    = os.path.join(mon_path, "mode")
                if not os.path.exists(current_f):
                    continue
                try:
                    with open(current_f) as f:
                        wid = f.read().strip()
                    title = id_to_title.get(wid, wid)
                    mode = ""
                    if os.path.exists(mode_f):
                        with open(mode_f) as f:
                            m = f.read().strip()
                        if m and m != "idle":
                            mode = f" [{m}]"
                    parts.append(f"{mon}: {title}{mode}")
                except OSError:
                    pass
        self._status_label.set_text("  |  ".join(parts) if parts else "No wallpaper active")
        return True

    # --- Keyboard shortcuts ---

    def _setup_keyboard(self):
        """Register keyboard shortcuts: / to focus search, Esc to clear it."""
        ctrl = Gtk.EventControllerKey.new()
        ctrl.connect("key-pressed", self._on_key_pressed)
        self.add_controller(ctrl)

    def _on_key_pressed(self, _ctrl, keyval, _keycode, _state):
        """Handle key-press events for search focus and clear shortcuts."""
        if keyval == Gdk.KEY_Escape:
            if self.search.get_text():
                self.search.set_text("")
                return True
        if keyval == Gdk.KEY_slash and not self.search.has_focus():
            self.search.grab_focus()
            return True
        return False

    def _on_settings(self, _btn):
        """Open the global settings modal."""
        win = SettingsWindow(self)
        win.present()

    def _on_playlists(self, _btn):
        """Open the playlist manager modal."""
        win = PlaylistWindow(self, self.wallpapers)
        win.present()

    def _on_logs(self, _btn):
        """Open a live log viewer with search and error highlighting."""
        if self._log_win is None or not self._log_win.get_visible():
            self._log_win = LogWindow(self)
        self._log_win.present()

    def _on_add_to_playlist(self, _btn):
        """Show a picker to add the selected wallpaper to a playlist."""
        if not self.selected_id:
            return
        self._overflow_popover.popdown()

        playlists = load_playlists()
        if not playlists:
            dialog = Gtk.Window(title="Add to Playlist", transient_for=self, modal=True)
            dialog.set_default_size(280, 100)
            box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
            box.set_margin_top(16)
            box.set_margin_bottom(16)
            box.set_margin_start(16)
            box.set_margin_end(16)
            box.append(Gtk.Label(label="No playlists yet. Create one first."))
            ok = Gtk.Button(label="OK")
            ok.connect("clicked", lambda _: dialog.close())
            box.append(ok)
            dialog.set_child(box)
            dialog.present()
            return

        win = Gtk.Window(title="Add to Playlist", transient_for=self, modal=True)
        win.set_default_size(260, 300)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_margin_top(8)
        box.set_margin_bottom(8)
        box.set_margin_start(8)
        box.set_margin_end(8)

        lbl = Gtk.Label(label="Select playlist:")
        lbl.set_halign(Gtk.Align.START)
        box.append(lbl)

        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroll.set_vexpand(True)
        lb = Gtk.ListBox()
        lb.set_selection_mode(Gtk.SelectionMode.SINGLE)
        for pl_name in playlists:
            row = Gtk.ListBoxRow()
            row.pl_name = pl_name
            row_lbl = Gtk.Label(label=pl_name)
            row_lbl.set_halign(Gtk.Align.START)
            row_lbl.set_margin_top(6)
            row_lbl.set_margin_bottom(6)
            row_lbl.set_margin_start(8)
            row_lbl.set_margin_end(8)
            row.set_child(row_lbl)
            lb.append(row)
        scroll.set_child(lb)
        box.append(scroll)

        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        add_btn = Gtk.Button(label="Add")
        add_btn.add_css_class("suggested-action")
        cancel_btn = Gtk.Button(label="Cancel")
        cancel_btn.connect("clicked", lambda _: win.close())
        btn_row.append(cancel_btn)
        btn_row.append(add_btn)
        box.append(btn_row)
        win.set_child(box)

        wall_id = self.selected_id

        def _do_add(_b):
            selected_row = lb.get_selected_row()
            if selected_row:
                playlist_cmd("add", selected_row.pl_name, wall_id)
                win.close()

        add_btn.connect("clicked", _do_add)
        lb.connect("row-activated", lambda _lb, _row: _do_add(None))
        win.present()

    # --- Actions ---

    def _on_activated(self, _listbox, row):
        """Double-click or Enter -- apply the wallpaper immediately."""
        if row is not None:
            self.selected_id = row.wall["id"]
        self._on_apply(None)

    def _steam_url(self):
        """Build a Steam Community workshop URL for the selected wallpaper."""
        return f"steam://url/CommunityFilePage/{self.selected_id}"

    def _on_open_steam(self, _btn):
        """Open the wallpaper's Steam workshop page in the default browser."""
        if not self.selected_id:
            return
        self._overflow_popover.popdown()
        gui_log(f"open steam: id={self.selected_id} url={self._steam_url()}")
        subprocess.Popen(["xdg-open", self._steam_url()])

    def _on_share(self, _btn):
        """Copy the Steam workshop URL to the clipboard."""
        if not self.selected_id:
            return
        self._overflow_popover.popdown()
        gui_log(f"copy steam url: id={self.selected_id} url={self._steam_url()}")
        Gdk.Display.get_default().get_clipboard().set(self._steam_url())

    def _on_copy_id(self, _btn):
        """Copy the selected wallpaper ID to the clipboard."""
        if not self.selected_id:
            return
        self._overflow_popover.popdown()
        gui_log(f"copy wallpaper id: id={self.selected_id}")
        Gdk.Display.get_default().get_clipboard().set(self.selected_id)

    def _on_report_issue(self, _btn):
        """Open the Report Issue dialog for the selected wallpaper."""
        if not self.selected_id:
            return
        self._overflow_popover.popdown()
        gui_log(f"report issue: id={self.selected_id}")
        win = ReportWindow(self, self.selected_id, self.title_label.get_text())
        win.present()

    def _on_apply(self, _btn):
        """Apply the selected wallpaper: persist staged props, then launch."""
        if not self.selected_id:
            return
        gui_log(f"apply requested: id={self.selected_id} staged_props={len(self._staged_props)}")
        # persist staged property overrides
        for key, val in self._staged_props.items():
            wall_cmd("prop", "set", self.selected_id, f"{key}={val}")
        item = self.mon_drop.get_selected_item()
        monitor = item.get_string() if item else "ALL"
        gui_log(f"apply monitor: id={self.selected_id} monitor={monitor}")
        apply_wallpaper(self.selected_id, monitor)


########################################
# REPORT WINDOW
########################################

class ReportWindow(Gtk.Window):
    """Dialog for filing a bug report against a specific wallpaper.

    Collects a problem description and category from the user, then calls
    ``wall report --no-interactive`` to write the report file.  After saving,
    a Share button uploads the file to 0x0.st and copies the URL.
    """

    CATEGORIES = [
        ("black-screen",  "Black screen / wallpaper not visible"),
        ("visual-glitch", "Visual glitch or corruption"),
        ("crash",         "Crash (engine exits immediately)"),
        ("performance",   "Performance / lag / low FPS"),
        ("audio",         "Audio issue"),
        ("script",        "Script or animation broken"),
        ("other",         "Other"),
    ]

    def __init__(self, parent, wall_id, wall_title):
        super().__init__(title="Report Issue", transient_for=parent, modal=True)
        self.set_default_size(520, 440)
        self._wall_id = wall_id
        self._wall_title = wall_title
        self._report_file = None
        self._build_ui()

    def _build_ui(self):
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        root.set_margin_top(16)
        root.set_margin_bottom(16)
        root.set_margin_start(16)
        root.set_margin_end(16)
        self.set_child(root)

        # Header
        hdr = Gtk.Label(label=f"Report an issue with:")
        hdr.set_halign(Gtk.Align.START)
        hdr.add_css_class("dim-label")
        root.append(hdr)

        wall_lbl = Gtk.Label(label=self._wall_title or self._wall_id)
        wall_lbl.set_halign(Gtk.Align.START)
        wall_lbl.add_css_class("heading")
        wall_lbl.set_ellipsize(Pango.EllipsizeMode.END)
        root.append(wall_lbl)

        root.append(Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL))

        # Category
        cat_lbl = Gtk.Label(label="Issue type")
        cat_lbl.set_halign(Gtk.Align.START)
        root.append(cat_lbl)

        cat_model = Gtk.StringList.new([label for _, label in self.CATEGORIES])
        self._cat_drop = Gtk.DropDown(model=cat_model)
        self._cat_drop.set_selected(len(self.CATEGORIES) - 1)  # default to "other"
        self._cat_drop.set_halign(Gtk.Align.FILL)
        root.append(self._cat_drop)

        # Description
        desc_lbl = Gtk.Label(label="Describe the problem")
        desc_lbl.set_halign(Gtk.Align.START)
        root.append(desc_lbl)

        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        scroll.set_vexpand(True)
        self._desc_view = Gtk.TextView()
        self._desc_view.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        self._desc_view.set_monospace(False)
        scroll.set_child(self._desc_view)
        root.append(scroll)

        # Status label (shown after save)
        self._status_lbl = Gtk.Label(label="")
        self._status_lbl.set_halign(Gtk.Align.START)
        self._status_lbl.add_css_class("dim-label")
        self._status_lbl.set_wrap(True)
        self._status_lbl.set_visible(False)
        root.append(self._status_lbl)

        # Buttons
        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)

        cancel_btn = Gtk.Button(label="Cancel")
        cancel_btn.connect("clicked", lambda _: self.close())
        btn_row.append(cancel_btn)

        spacer = Gtk.Box()
        spacer.set_hexpand(True)
        btn_row.append(spacer)

        self._open_folder_btn = Gtk.Button(label="Open Folder")
        self._open_folder_btn.set_tooltip_text("Open the reports folder to share the file")
        self._open_folder_btn.set_visible(False)
        self._open_folder_btn.connect("clicked", self._on_open_folder)
        btn_row.append(self._open_folder_btn)

        self._save_btn = Gtk.Button(label="Save Report")
        self._save_btn.add_css_class("suggested-action")
        self._save_btn.connect("clicked", self._on_save)
        btn_row.append(self._save_btn)

        root.append(btn_row)

    def _on_save(self, _btn):
        """Collect form data and call wall report --no-interactive."""
        buf = self._desc_view.get_buffer()
        desc = buf.get_text(buf.get_start_iter(), buf.get_end_iter(), False).strip()
        if not desc:
            self._status_lbl.set_text("Please enter a description.")
            self._status_lbl.set_visible(True)
            return

        cat_idx = self._cat_drop.get_selected()
        category = self.CATEGORIES[cat_idx][0] if cat_idx < len(self.CATEGORIES) else "other"

        self._save_btn.set_sensitive(False)
        self._save_btn.set_label("Saving…")

        def _do_save():
            result = wall_cmd(
                "report",
                "--id", self._wall_id,
                "--desc", desc,
                "--category", category,
                "--no-interactive",
            )
            GLib.idle_add(self._on_saved, result)

        threading.Thread(target=_do_save, daemon=True).start()

    def _on_saved(self, output):
        """Update UI after wall report completes."""
        self._save_btn.set_sensitive(True)
        self._save_btn.set_label("Save Report")

        # The last non-empty line of output is the file path
        lines = [l for l in (output or "").splitlines() if l.strip()]
        file_path = lines[-1] if lines else ""

        if file_path and os.path.isfile(file_path):
            self._report_file = file_path
            self._status_lbl.set_text(f"Saved: {os.path.basename(file_path)}")
            self._status_lbl.set_visible(True)
            self._open_folder_btn.set_visible(True)
            self._save_btn.set_label("Saved ✓")
            self._save_btn.set_sensitive(False)
            gui_log(f"report saved: {file_path}")
        else:
            self._status_lbl.set_text("Failed to save report. Check wall log for details.")
            self._status_lbl.set_visible(True)
            gui_log(f"report save failed, output={output!r}")
        return False

    def _on_open_folder(self, _btn):
        """Open the reports folder in the system file manager."""
        reports_dir = os.path.expanduser("~/.config/wall/reports")
        os.makedirs(reports_dir, exist_ok=True)
        gui_log(f"open reports folder: {reports_dir}")
        subprocess.Popen(["xdg-open", reports_dir])


########################################
# APP
########################################

class App(Gtk.Application):
    """GTK Application entry point."""

    def __init__(self):
        super().__init__()

    def do_activate(self):
        """Create and present the main window."""
        gui_log("app activate")
        win = WallGui(self)
        win.present()


if __name__ == "__main__":
    gui_log("app start")
    App().run(None)
