#!/usr/bin/env python3

import gi
gi.require_version('Gtk', '4.0')
from gi.repository import Gtk, Gdk, GLib, Pango

import json
import os
import re
import subprocess
import shutil

MEDIA_EXTS = {".mp4", ".webm", ".gif"}

########################################
# BBCODE → PANGO MARKUP
########################################

def bbcode_to_pango(text):
    """Convert Wallpaper Engine BBCode to Pango markup for Gtk.Label."""
    # Escape Pango XML special chars first
    text = text.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")

    # Tags that map directly to Pango
    simple = [
        (r'\[b\](.*?)\[/b\]',           r'<b>\1</b>'),
        (r'\[i\](.*?)\[/i\]',           r'<i>\1</i>'),
        (r'\[u\](.*?)\[/u\]',           r'<u>\1</u>'),
        (r'\[s\](.*?)\[/s\]',           r'<s>\1</s>'),
        (r'\[strike\](.*?)\[/strike\]', r'<s>\1</s>'),
        (r'\[h[1-3]\](.*?)\[/h[1-3]\]', r'<b>\1</b>'),
        (r'\[url=([^\]]+)\](.*?)\[/url\]', r'<a href="\1">\2</a>'),
        (r'\[url\](.*?)\[/url\]',        r'<a href="\1">\1</a>'),
        (r'\[img\].*?\[/img\]',          r''),
        (r'\[noparse\](.*?)\[/noparse\]', r'\1'),
        (r'\[list\]|\[/list\]',          r''),
        (r'\[\*\]',                       r'• '),
    ]
    for pattern, repl in simple:
        text = re.sub(pattern, repl, text, flags=re.DOTALL | re.IGNORECASE)

    # Strip any remaining unknown [tags]
    text = re.sub(r'\[/?[a-zA-Z][^\]]*\]', '', text)

    return text.strip()

########################################
# WALL CLI
########################################

def get_wall_bin():
    return shutil.which("wall") or os.path.expanduser("~/.local/bin/wall")


def wall_cmd(*args):
    """Run a wall subcommand, return stdout as a string."""
    return subprocess.run(
        [get_wall_bin(), *args],
        capture_output=True, text=True
    ).stdout


def load_wallpapers():
    """Fetch wallpaper list via `wall list`.
    Output format: MARKER\\tID\\tTITLE\\tTAGS\\tTYPE
    """
    walls = []
    for line in wall_cmd("list").splitlines():
        parts = line.split("\t")
        if len(parts) >= 3:
            walls.append({
                "active": parts[0].strip() == "*",
                "id":     parts[1],
                "title":  parts[2],
                "tags":   parts[3] if len(parts) > 3 else "",
                "type":   parts[4].capitalize() if len(parts) > 4 else "",
                "desc":   parts[5] if len(parts) > 5 else "",
            })
    return walls


def load_info(wall_id):
    """Fetch full wallpaper details via `wall info <id>`.
    Returns a dict with title, type, description, tags, visibility, thumbnail, id,
    video (optional), properties (optional).
    """
    try:
        return json.loads(wall_cmd("info", wall_id))
    except Exception:
        return {}


def get_monitors():
    """Fetch connected monitors via `wall monitors`."""
    mons = [m.strip() for m in wall_cmd("monitors").splitlines() if m.strip()]
    return mons if mons else ["*"]


def apply_wallpaper(wall_id, monitor):
    """Apply wallpaper via `wall <id> [monitor]`."""
    cmd = [get_wall_bin(), wall_id]
    if monitor != "ALL":
        cmd.append(monitor)
    subprocess.Popen(cmd)


def load_saved_props(wall_id):
    """Load saved property overrides from ~/.config/wall/props/<id>."""
    props_file = os.path.expanduser(f"~/.config/wall/props/{wall_id}")
    saved = {}
    if os.path.exists(props_file):
        with open(props_file) as f:
            for line in f:
                line = line.strip()
                if "=" in line:
                    k, v = line.split("=", 1)
                    saved[k] = v
    return saved


########################################
# WINDOW
########################################

class WallGui(Gtk.ApplicationWindow):

    def __init__(self, app):
        super().__init__(application=app, title="wall-gui")
        self.set_default_size(1020, 640)

        self.wallpapers     = load_wallpapers()
        self.selected_id    = None
        self.monitors       = get_monitors()
        self._current_media = None
        self._staged_props  = {}

        self._build_ui()
        self._populate_list()

    # --------------------------------------------------
    # UI
    # --------------------------------------------------

    def _build_ui(self):
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.set_child(root)

        # search bar
        self.search = Gtk.SearchEntry()
        self.search.set_placeholder_text("Search by title or tags…")
        self.search.set_margin_top(8)
        self.search.set_margin_bottom(8)
        self.search.set_margin_start(8)
        self.search.set_margin_end(8)
        self.search.connect("search-changed", lambda _: self.listbox.invalidate_filter())
        root.append(self.search)

        root.append(Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL))

        # paned layout
        paned = Gtk.Paned(orientation=Gtk.Orientation.HORIZONTAL)
        paned.set_vexpand(True)
        paned.set_position(340)
        root.append(paned)

        # left pane — list
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.listbox = Gtk.ListBox()
        self.listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self.listbox.set_activate_on_single_click(False)
        self.listbox.set_filter_func(self._filter)
        self.listbox.connect("row-selected", self._on_selected)
        self.listbox.connect("row-activated", self._on_activated)
        scroll.set_child(self.listbox)
        paned.set_start_child(scroll)
        paned.set_shrink_start_child(False)

        # right pane — details
        right_scroll = Gtk.ScrolledWindow()
        right_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        right_scroll.set_hexpand(True)

        right = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        right.set_margin_top(16)
        right.set_margin_bottom(16)
        right.set_margin_start(16)
        right.set_margin_end(16)
        right_scroll.set_child(right)
        paned.set_end_child(right_scroll)
        paned.set_shrink_end_child(False)

        self.thumbnail = Gtk.Picture()
        self.thumbnail.set_size_request(-1, 220)
        self.thumbnail.set_content_fit(Gtk.ContentFit.CONTAIN)
        self.thumbnail.set_can_shrink(True)
        right.append(self.thumbnail)

        # warnings banner (hidden by default)
        self._warn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self._warn_box.set_margin_top(4)
        self._warn_box.set_margin_bottom(4)
        self._warn_box.set_margin_start(4)
        self._warn_box.set_margin_end(4)
        self._warn_box.add_css_class("card")
        self._warn_box.set_visible(False)

        warn_icon = Gtk.Label(label="⚠")
        warn_icon.add_css_class("warning")
        self._warn_box.append(warn_icon)

        self._warn_label = Gtk.Label(label="")
        self._warn_label.set_halign(Gtk.Align.START)
        self._warn_label.set_wrap(True)
        self._warn_label.set_hexpand(True)
        self._warn_label.set_use_markup(True)
        self._warn_label.add_css_class("warning")
        self._warn_box.append(self._warn_label)

        right.append(self._warn_box)

        self.title_label = Gtk.Label(label="Select a wallpaper")
        self.title_label.set_halign(Gtk.Align.START)
        self.title_label.set_wrap(True)
        self.title_label.add_css_class("title-3")
        right.append(self.title_label)

        meta_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        right.append(meta_row)

        self.type_label = Gtk.Label(label="")
        self.type_label.set_halign(Gtk.Align.START)
        self.type_label.add_css_class("dim-label")
        meta_row.append(self.type_label)

        self.visibility_label = Gtk.Label(label="")
        self.visibility_label.set_halign(Gtk.Align.START)
        self.visibility_label.add_css_class("dim-label")
        meta_row.append(self.visibility_label)

        self.active_label = Gtk.Label(label="")
        self.active_label.set_halign(Gtk.Align.START)
        self.active_label.add_css_class("accent")
        meta_row.append(self.active_label)

        self.resolution_label = Gtk.Label(label="")
        self.resolution_label.set_halign(Gtk.Align.START)
        self.resolution_label.add_css_class("dim-label")
        right.append(self.resolution_label)

        self.desc_label = Gtk.Label(label="")
        self.desc_label.set_halign(Gtk.Align.START)
        self.desc_label.set_wrap(True)
        self.desc_label.set_max_width_chars(48)
        self.desc_label.set_use_markup(True)
        right.append(self.desc_label)

        self.tags_label = Gtk.Label(label="")
        self.tags_label.set_halign(Gtk.Align.START)
        self.tags_label.set_wrap(True)
        self.tags_label.add_css_class("dim-label")
        right.append(self.tags_label)

        self.id_label = Gtk.Label(label="")
        self.id_label.set_halign(Gtk.Align.START)
        self.id_label.add_css_class("dim-label")
        right.append(self.id_label)

        self._exclude_check = Gtk.CheckButton(label="Exclude from random / cycle / shuffle")
        self._exclude_check.set_halign(Gtk.Align.START)
        self._exclude_check.set_sensitive(False)
        self._exclude_handler = self._exclude_check.connect("toggled", self._on_exclude_toggled)
        right.append(self._exclude_check)

        # properties section (hidden until a wallpaper with properties is selected)
        self._props_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        self._props_box.set_visible(False)
        right.append(self._props_box)

        spacer = Gtk.Box()
        spacer.set_vexpand(True)
        right.append(spacer)

        action = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        right.append(action)

        mon_list = Gtk.StringList.new(self.monitors + (["ALL"] if len(self.monitors) > 1 else []))
        self.mon_drop = Gtk.DropDown(model=mon_list)
        if len(self.monitors) > 1:
            self.mon_drop.set_selected(len(self.monitors))
        action.append(self.mon_drop)

        self.open_btn = Gtk.Button(label="Open in Steam")
        self.open_btn.set_sensitive(False)
        self.open_btn.connect("clicked", self._on_open_steam)
        action.append(self.open_btn)

        self.share_btn = Gtk.Button(label="Share")
        self.share_btn.set_sensitive(False)
        self.share_btn.connect("clicked", self._on_share)
        action.append(self.share_btn)

        self.apply_btn = Gtk.Button(label="Apply")
        self.apply_btn.add_css_class("suggested-action")
        self.apply_btn.set_hexpand(True)
        self.apply_btn.set_sensitive(False)
        self.apply_btn.connect("clicked", self._on_apply)
        action.append(self.apply_btn)

        self.search.grab_focus()

    def _populate_list(self):
        if not self.wallpapers:
            empty = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
            empty.set_valign(Gtk.Align.CENTER)
            empty.set_vexpand(True)
            empty.set_margin_top(40)
            empty.set_margin_bottom(40)
            empty.set_margin_start(24)
            empty.set_margin_end(24)

            icon = Gtk.Label(label="¯\\_(ツ)_/¯")
            icon.add_css_class("title-1")
            empty.append(icon)

            msg = Gtk.Label()
            msg.set_markup(
                "<b>Nothing to put on your walls.</b>\n\n"
                "Either Steam is still waking up,\n"
                "or your Wallpaper Engine workshop\n"
                "is as empty as this window.\n\n"
                "<tt>wall cache rebuild</tt>"
            )
            msg.set_justify(Gtk.Justification.CENTER)
            msg.add_css_class("dim-label")
            empty.append(msg)

            self.listbox.append(Gtk.ListBoxRow(child=empty, selectable=False))
            return

        for wall in self.wallpapers:
            row = Gtk.ListBoxRow()
            row.wall = wall

            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            box.set_margin_top(6)
            box.set_margin_bottom(6)
            box.set_margin_start(12)
            box.set_margin_end(12)

            if wall["active"]:
                dot = Gtk.Label(label="▶")
                dot.add_css_class("accent")
                box.append(dot)

            text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            text_box.set_hexpand(True)

            title = Gtk.Label(label=wall["title"])
            title.set_halign(Gtk.Align.START)
            title.set_ellipsize(Pango.EllipsizeMode.END)
            text_box.append(title)

            sub = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
            if wall["type"]:
                type_lbl = Gtk.Label(label=wall["type"])
                type_lbl.add_css_class("dim-label")
                type_lbl.set_halign(Gtk.Align.START)
                sub.append(type_lbl)

            if wall["tags"]:
                tags_lbl = Gtk.Label(label=wall["tags"])
                tags_lbl.set_halign(Gtk.Align.START)
                tags_lbl.set_ellipsize(Pango.EllipsizeMode.END)
                tags_lbl.add_css_class("dim-label")
                sub.append(tags_lbl)

            if wall["type"] or wall["tags"]:
                text_box.append(sub)

            box.append(text_box)
            row.set_child(box)
            self.listbox.append(row)

    # --------------------------------------------------
    # CALLBACKS
    # --------------------------------------------------

    def _filter(self, row):
        query = self.search.get_text().lower()
        if not query:
            return True
        w = row.wall
        return query in w["title"].lower() or query in w["tags"].lower() or query in w["desc"].lower()

    def _on_selected(self, _listbox, row):
        """Single click — update preview panel via wall info."""
        if row is None:
            return
        wall = row.wall
        self.selected_id = wall["id"]
        self.apply_btn.set_sensitive(True)
        self.share_btn.set_sensitive(True)
        self.open_btn.set_sensitive(True)

        info = load_info(wall["id"])

        warnings = info.get("warnings", [])
        if warnings:
            self._warn_label.set_markup("<big><b>" + " · ".join(warnings) + "</b></big>")
            self._warn_box.set_visible(True)
        else:
            self._warn_box.set_visible(False)

        self.title_label.set_text(info.get("title", wall["title"]))
        self.type_label.set_text(info.get("type", wall["type"]).capitalize())

        visibility = info.get("visibility", "")
        self.visibility_label.set_text(f"· {visibility}" if visibility else "")
        self.active_label.set_text("· active" if wall["active"] else "")

        video = info.get("video", {})
        if video and video.get("width"):
            w, h   = video["width"], video["height"]
            fps    = int(video.get("fps", 0))
            dur    = int(video.get("duration", 0))
            codec  = video.get("codec", "")
            parts  = [f"{w}×{h}"]
            if fps:
                parts.append(f"{fps}fps")
            if dur:
                parts.append(f"{dur // 60}:{dur % 60:02d}")
            if codec:
                parts.append(codec)
            self.resolution_label.set_text(" · ".join(parts))
        else:
            self.resolution_label.set_text("")

        desc = info.get("description", "").strip()
        if desc:
            try:
                self.desc_label.set_markup(bbcode_to_pango(desc))
            except Exception:
                self.desc_label.set_text(desc)
        else:
            self.desc_label.set_text("")
        self.desc_label.set_visible(bool(desc))

        tags = ", ".join(info.get("tags", [])) or wall["tags"]
        self.tags_label.set_text(f"Tags: {tags}" if tags else "")
        self.id_label.set_text(f"ID: {wall['id']}")

        # update exclude checkbox without triggering the toggle handler
        self._exclude_check.handler_block(self._exclude_handler)
        self._exclude_check.set_active(info.get("excluded", False))
        self._exclude_check.set_sensitive(True)
        self._exclude_check.handler_unblock(self._exclude_handler)

        self._update_preview(info.get("thumbnail", ""))
        self._build_properties_panel(info.get("properties", []), wall["id"])

    def _update_preview(self, thumb):
        if self._current_media is not None:
            self._current_media.pause()
            self._current_media = None

        if not thumb:
            self.thumbnail.set_file(None)
            return

        ext = os.path.splitext(thumb)[1].lower()
        if ext in MEDIA_EXTS:
            try:
                media = Gtk.MediaFile.new_for_filename(thumb)
                media.set_loop(True)
                media.play()
                self.thumbnail.set_paintable(media)
                self._current_media = media
            except Exception:
                self.thumbnail.set_filename(thumb)
        else:
            self.thumbnail.set_filename(thumb)

    # --------------------------------------------------
    # PROPERTIES PANEL
    # --------------------------------------------------

    def _build_properties_panel(self, properties, wall_id):
        """Rebuild the properties section for the selected wallpaper."""
        # clear existing widgets
        child = self._props_box.get_first_child()
        while child:
            nxt = child.get_next_sibling()
            self._props_box.remove(child)
            child = nxt

        self._staged_props = {}
        self._props_box.set_visible(False)

        if not properties:
            return

        saved = load_saved_props(wall_id)

        self._props_box.set_visible(True)

        sep = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        self._props_box.append(sep)

        header = Gtk.Label(label="Properties")
        header.set_halign(Gtk.Align.START)
        header.add_css_class("heading")
        self._props_box.append(header)

        grid = Gtk.Grid()
        grid.set_column_spacing(12)
        grid.set_row_spacing(8)
        self._props_box.append(grid)

        for i, prop in enumerate(properties):
            key   = prop.get("key", "")
            ptype = prop.get("type", "")
            label_text = prop.get("label", key)
            current_val = saved.get(key, prop.get("value", ""))

            lbl = Gtk.Label(label=label_text)
            lbl.set_halign(Gtk.Align.START)
            lbl.set_hexpand(True)
            grid.attach(lbl, 0, i, 1, 1)

            widget = self._make_prop_widget(key, ptype, current_val, prop)
            if widget:
                grid.attach(widget, 1, i, 1, 1)

    def _make_prop_widget(self, key, ptype, value, prop):
        if ptype == "bool":
            sw = Gtk.Switch()
            sw.set_active(str(value).lower() in ("true", "1"))
            sw.set_halign(Gtk.Align.START)
            sw.set_valign(Gtk.Align.CENTER)
            sw.connect("state-set", lambda w, s: self._stage(key, "true" if s else "false"))
            return sw

        if ptype == "slider":
            try:
                lo   = float(prop.get("min") or 0)
                hi   = float(prop.get("max") or 1)
                step = float(prop.get("step") or 0.01)
                cur  = float(value) if value else lo
            except (ValueError, TypeError):
                lo, hi, step, cur = 0.0, 1.0, 0.01, 0.0

            adj   = Gtk.Adjustment(value=cur, lower=lo, upper=hi, step_increment=step)
            scale = Gtk.Scale(orientation=Gtk.Orientation.HORIZONTAL, adjustment=adj)
            scale.set_hexpand(True)
            scale.set_size_request(160, -1)
            scale.set_draw_value(True)
            scale.set_digits(2)
            scale.connect("value-changed", lambda w: self._stage(key, f"{w.get_value():.4g}"))
            return scale

        if ptype == "color":
            try:
                parts = [float(x) for x in str(value).split()]
                r = parts[0] if len(parts) > 0 else 1.0
                g = parts[1] if len(parts) > 1 else 1.0
                b = parts[2] if len(parts) > 2 else 1.0
            except (ValueError, IndexError):
                r, g, b = 1.0, 1.0, 1.0

            rgba = Gdk.RGBA()
            rgba.red, rgba.green, rgba.blue, rgba.alpha = r, g, b, 1.0
            btn = Gtk.ColorButton()
            btn.set_rgba(rgba)
            btn.connect("color-set", lambda w: self._on_color_set(w, key))
            return btn

        if ptype == "combo":
            options = prop.get("options") or []
            if options:
                labels = [o.get("label", str(o.get("value", ""))) for o in options]
                values = [str(o.get("value", "")) for o in options]
                model  = Gtk.StringList.new(labels)
                dd     = Gtk.DropDown(model=model)
                try:
                    dd.set_selected(values.index(str(value)))
                except ValueError:
                    pass
                dd.connect("notify::selected",
                           lambda w, _: self._on_combo_changed(w, key, values))
                return dd

        if ptype in ("text", "textinput"):
            entry = Gtk.Entry()
            entry.set_text(str(value))
            entry.set_hexpand(True)
            entry.connect("changed", lambda w: self._stage(key, w.get_text()))
            return entry

        return None

    def _stage(self, key, value):
        self._staged_props[key] = value

    def _on_color_set(self, btn, key):
        rgba = btn.get_rgba()
        self._staged_props[key] = f"{rgba.red:.4f} {rgba.green:.4f} {rgba.blue:.4f}"

    def _on_combo_changed(self, dropdown, key, values):
        idx = dropdown.get_selected()
        if 0 <= idx < len(values):
            self._staged_props[key] = values[idx]

    def _on_exclude_toggled(self, btn):
        if not self.selected_id:
            return
        if btn.get_active():
            wall_cmd("exclude", self.selected_id)
        else:
            wall_cmd("include", self.selected_id)

    # --------------------------------------------------
    # ACTIONS
    # --------------------------------------------------

    def _on_activated(self, _listbox, row):
        """Double-click or Enter — apply immediately."""
        if row is not None:
            self.selected_id = row.wall["id"]
        self._on_apply(None)

    def _steam_url(self):
        return f"steam://url/CommunityFilePage/{self.selected_id}"

    def _on_open_steam(self, _btn):
        if not self.selected_id:
            return
        subprocess.Popen(["xdg-open", self._steam_url()])

    def _on_share(self, btn):
        if not self.selected_id:
            return
        Gdk.Display.get_default().get_clipboard().set(self._steam_url())
        btn.set_label("Copied!")
        GLib.timeout_add(1500, lambda: btn.set_label("Share") or False)

    def _on_apply(self, _btn):
        if not self.selected_id:
            return
        # persist staged property overrides
        for key, val in self._staged_props.items():
            wall_cmd("prop", "set", self.selected_id, f"{key}={val}")
        item = self.mon_drop.get_selected_item()
        monitor = item.get_string() if item else "ALL"
        apply_wallpaper(self.selected_id, monitor)


########################################
# APP
########################################

class App(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="com.github.bbetter.wall-gui")

    def do_activate(self):
        win = WallGui(self)
        win.present()


if __name__ == "__main__":
    App().run(None)
