#!/usr/bin/env python3

import gi
gi.require_version('Gtk', '4.0')
from gi.repository import Gtk, Gdk, GLib, Pango

import json
import os
import subprocess
import shutil

MEDIA_EXTS = {".mp4", ".webm", ".gif"}

########################################
# WALL CLI
########################################

def get_wall_bin():
    return shutil.which("wall") or os.path.expanduser("~/.local/bin/wall")


def wall_cmd(*args):
    """Run a wall subcommand, return stdout as a string."""
    return subprocess.run(
        [get_wall_bin(), *args],
        capture_output=True, text=True
    ).stdout


def load_wallpapers():
    """Fetch wallpaper list via `wall list`.
    Output format: MARKER\\tID\\tTITLE\\tTAGS\\tTYPE
    """
    walls = []
    for line in wall_cmd("list").splitlines():
        parts = line.split("\t")
        if len(parts) >= 3:
            walls.append({
                "active": parts[0].strip() == "*",
                "id":     parts[1],
                "title":  parts[2],
                "tags":   parts[3] if len(parts) > 3 else "",
                "type":   parts[4].capitalize() if len(parts) > 4 else "",
            })
    return walls


def load_info(wall_id):
    """Fetch full wallpaper details via `wall info <id>`.
    Returns a dict with title, type, description, tags, visibility, thumbnail, id.
    """
    try:
        return json.loads(wall_cmd("info", wall_id))
    except Exception:
        return {}


def get_monitors():
    """Fetch connected monitors via `wall monitors`."""
    mons = [m.strip() for m in wall_cmd("monitors").splitlines() if m.strip()]
    return mons if mons else ["*"]


def apply_wallpaper(wall_id, monitor):
    """Apply wallpaper via `wall <id> [monitor]`."""
    cmd = [get_wall_bin(), wall_id]
    if monitor != "ALL":
        cmd.append(monitor)
    subprocess.Popen(cmd)


########################################
# WINDOW
########################################

class WallPicker(Gtk.ApplicationWindow):

    def __init__(self, app):
        super().__init__(application=app, title="wall-picker")
        self.set_default_size(980, 600)

        self.wallpapers     = load_wallpapers()
        self.selected_id    = None
        self.monitors       = get_monitors()
        self._current_media = None

        self._build_ui()
        self._populate_list()

    # --------------------------------------------------
    # UI
    # --------------------------------------------------

    def _build_ui(self):
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.set_child(root)

        # search bar
        self.search = Gtk.SearchEntry()
        self.search.set_placeholder_text("Search by title or tags…")
        self.search.set_margin_top(8)
        self.search.set_margin_bottom(8)
        self.search.set_margin_start(8)
        self.search.set_margin_end(8)
        self.search.connect("search-changed", lambda _: self.listbox.invalidate_filter())
        root.append(self.search)

        root.append(Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL))

        # paned layout
        paned = Gtk.Paned(orientation=Gtk.Orientation.HORIZONTAL)
        paned.set_vexpand(True)
        paned.set_position(340)
        root.append(paned)

        # left pane — list
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.listbox = Gtk.ListBox()
        self.listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self.listbox.set_activate_on_single_click(False)
        self.listbox.set_filter_func(self._filter)
        self.listbox.connect("row-selected", self._on_selected)
        self.listbox.connect("row-activated", self._on_activated)
        scroll.set_child(self.listbox)
        paned.set_start_child(scroll)
        paned.set_shrink_start_child(False)

        # right pane — details
        right_scroll = Gtk.ScrolledWindow()
        right_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        right_scroll.set_hexpand(True)

        right = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        right.set_margin_top(16)
        right.set_margin_bottom(16)
        right.set_margin_start(16)
        right.set_margin_end(16)
        right_scroll.set_child(right)
        paned.set_end_child(right_scroll)
        paned.set_shrink_end_child(False)

        self.thumbnail = Gtk.Picture()
        self.thumbnail.set_size_request(-1, 220)
        self.thumbnail.set_content_fit(Gtk.ContentFit.CONTAIN)
        self.thumbnail.set_can_shrink(True)
        right.append(self.thumbnail)

        self.title_label = Gtk.Label(label="Select a wallpaper")
        self.title_label.set_halign(Gtk.Align.START)
        self.title_label.set_wrap(True)
        self.title_label.add_css_class("title-3")
        right.append(self.title_label)

        meta_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        right.append(meta_row)

        self.type_label = Gtk.Label(label="")
        self.type_label.set_halign(Gtk.Align.START)
        self.type_label.add_css_class("dim-label")
        meta_row.append(self.type_label)

        self.visibility_label = Gtk.Label(label="")
        self.visibility_label.set_halign(Gtk.Align.START)
        self.visibility_label.add_css_class("dim-label")
        meta_row.append(self.visibility_label)

        self.active_label = Gtk.Label(label="")
        self.active_label.set_halign(Gtk.Align.START)
        self.active_label.add_css_class("accent")
        meta_row.append(self.active_label)

        self.desc_label = Gtk.Label(label="")
        self.desc_label.set_halign(Gtk.Align.START)
        self.desc_label.set_wrap(True)
        self.desc_label.set_max_width_chars(48)
        right.append(self.desc_label)

        self.tags_label = Gtk.Label(label="")
        self.tags_label.set_halign(Gtk.Align.START)
        self.tags_label.set_wrap(True)
        self.tags_label.add_css_class("dim-label")
        right.append(self.tags_label)

        self.id_label = Gtk.Label(label="")
        self.id_label.set_halign(Gtk.Align.START)
        self.id_label.add_css_class("dim-label")
        right.append(self.id_label)

        spacer = Gtk.Box()
        spacer.set_vexpand(True)
        right.append(spacer)

        action = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        right.append(action)

        mon_list = Gtk.StringList.new(self.monitors + (["ALL"] if len(self.monitors) > 1 else []))
        self.mon_drop = Gtk.DropDown(model=mon_list)
        if len(self.monitors) > 1:
            self.mon_drop.set_selected(len(self.monitors))
        action.append(self.mon_drop)

        self.open_btn = Gtk.Button(label="Open in Steam")
        self.open_btn.set_sensitive(False)
        self.open_btn.connect("clicked", self._on_open_steam)
        action.append(self.open_btn)

        self.share_btn = Gtk.Button(label="Share")
        self.share_btn.set_sensitive(False)
        self.share_btn.connect("clicked", self._on_share)
        action.append(self.share_btn)

        self.apply_btn = Gtk.Button(label="Apply")
        self.apply_btn.add_css_class("suggested-action")
        self.apply_btn.set_hexpand(True)
        self.apply_btn.set_sensitive(False)
        self.apply_btn.connect("clicked", self._on_apply)
        action.append(self.apply_btn)

        self.search.grab_focus()

    def _populate_list(self):
        for wall in self.wallpapers:
            row = Gtk.ListBoxRow()
            row.wall = wall

            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            box.set_margin_top(6)
            box.set_margin_bottom(6)
            box.set_margin_start(12)
            box.set_margin_end(12)

            if wall["active"]:
                dot = Gtk.Label(label="▶")
                dot.add_css_class("accent")
                box.append(dot)

            text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            text_box.set_hexpand(True)

            title = Gtk.Label(label=wall["title"])
            title.set_halign(Gtk.Align.START)
            title.set_ellipsize(Pango.EllipsizeMode.END)
            text_box.append(title)

            sub = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
            if wall["type"]:
                type_lbl = Gtk.Label(label=wall["type"])
                type_lbl.add_css_class("dim-label")
                type_lbl.set_halign(Gtk.Align.START)
                sub.append(type_lbl)

            if wall["tags"]:
                tags_lbl = Gtk.Label(label=wall["tags"])
                tags_lbl.set_halign(Gtk.Align.START)
                tags_lbl.set_ellipsize(Pango.EllipsizeMode.END)
                tags_lbl.add_css_class("dim-label")
                sub.append(tags_lbl)

            if wall["type"] or wall["tags"]:
                text_box.append(sub)

            box.append(text_box)
            row.set_child(box)
            self.listbox.append(row)

    # --------------------------------------------------
    # CALLBACKS
    # --------------------------------------------------

    def _filter(self, row):
        query = self.search.get_text().lower()
        if not query:
            return True
        w = row.wall
        return query in w["title"].lower() or query in w["tags"].lower()

    def _on_selected(self, _listbox, row):
        """Single click — update preview panel via wall info."""
        if row is None:
            return
        wall = row.wall
        self.selected_id = wall["id"]
        self.apply_btn.set_sensitive(True)
        self.share_btn.set_sensitive(True)
        self.open_btn.set_sensitive(True)

        info = load_info(wall["id"])

        self.title_label.set_text(info.get("title", wall["title"]))
        self.type_label.set_text(info.get("type", wall["type"]).capitalize())

        visibility = info.get("visibility", "")
        self.visibility_label.set_text(f"· {visibility}" if visibility else "")
        self.active_label.set_text("· active" if wall["active"] else "")

        desc = info.get("description", "").strip()
        self.desc_label.set_text(desc)
        self.desc_label.set_visible(bool(desc))

        tags = ", ".join(info.get("tags", [])) or wall["tags"]
        self.tags_label.set_text(f"Tags: {tags}" if tags else "")
        self.id_label.set_text(f"ID: {wall['id']}")

        self._update_preview(info.get("thumbnail", ""))

    def _update_preview(self, thumb):
        if self._current_media is not None:
            self._current_media.pause()
            self._current_media = None

        if not thumb:
            self.thumbnail.set_file(None)
            return

        ext = os.path.splitext(thumb)[1].lower()
        if ext in MEDIA_EXTS:
            try:
                media = Gtk.MediaFile.new_for_filename(thumb)
                media.set_loop(True)
                media.play()
                self.thumbnail.set_paintable(media)
                self._current_media = media
            except Exception:
                self.thumbnail.set_filename(thumb)
        else:
            self.thumbnail.set_filename(thumb)

    def _on_activated(self, _listbox, row):
        """Double-click or Enter — apply immediately."""
        if row is not None:
            self.selected_id = row.wall["id"]
        self._on_apply(None)

    def _steam_url(self):
        return f"steam://url/CommunityFilePage/{self.selected_id}"

    def _on_open_steam(self, _btn):
        if not self.selected_id:
            return
        subprocess.Popen(["xdg-open", self._steam_url()])

    def _on_share(self, btn):
        if not self.selected_id:
            return
        Gdk.Display.get_default().get_clipboard().set(self._steam_url())
        btn.set_label("Copied!")
        GLib.timeout_add(1500, lambda: btn.set_label("Share") or False)

    def _on_apply(self, _btn):
        if not self.selected_id:
            return
        item = self.mon_drop.get_selected_item()
        monitor = item.get_string() if item else "ALL"
        apply_wallpaper(self.selected_id, monitor)
        self.close()


########################################
# APP
########################################

class App(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="com.github.bbetter.wall-picker")

    def do_activate(self):
        win = WallPicker(self)
        win.present()


if __name__ == "__main__":
    App().run(None)
