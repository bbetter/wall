#!/usr/bin/env bash

CONFIG="$HOME/.config/wall/config"
[ -f "$CONFIG" ] && source "$CONFIG"

DIR="$STEAM_LIB/workshop/content/431960/$1"

for f in preview.mp4 preview.webm preview.gif preview.jpg preview.png; do
    if [ -f "$DIR/$f" ]; then
        PREVIEW="$DIR/$f"
        break
    fi
done

pkill -f "mpv --title=wall-preview" 2>/dev/null

[ -z "$PREVIEW" ] && exit

mpv \
  --title=wall-preview \
  --loop \
  --no-border \
  --ontop \
  --autofit=640x360 \
  --image-display-duration=inf \
  "$PREVIEW" &
